# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Claude / Anthropic (informes semanales IA)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
# Opcional: si no se define, se usa claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6
# Webhook n8n para enviar informe HTML a socios
N8N_WEEKLY_REPORT_WEBHOOK_URL=https://your-n8n-instance/webhook/weekly-report

# App Configuration
NEXT_PUBLIC_DEFAULT_COST_PER_HOUR=30
NEXT_PUBLIC_CURRENCY=EUR

# IMPORTANTE: Este archivo es un ejemplo
# 1. Copia este archivo como .env.local
# 2. Reemplaza los valores con tus credenciales reales de Supabase
# 3. Nunca subas .env.local a Git (ya está en .gitignore)
